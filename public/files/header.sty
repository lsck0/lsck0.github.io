% derivatives
\newcommand{\del}{\partial}
\DeclareDocumentCommand{\dfrac}{m g}{
    \IfNoValueTF{#2}{
        \frac{\cd}{\cd #1}
    }{
        \frac{\cd #1}{\cd #2}
    }
}
\DeclareDocumentCommand{\pfrac}{m g}{
    \IfNoValueTF{#2}{
        \frac{\del}{\del #1}
    }{
        \frac{\del #1}{\del #2}
    }
}

