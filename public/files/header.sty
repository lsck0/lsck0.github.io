}

\def\useCommutativeDiagrams{
    \usepackage{tikz}
    \usepackage{tikz-cd}

    \newenvironment{diagram}{
        \begin{center}
        \begin{tikzcd}
    }{
        \end{tikzcd}
        \end{center}
    }
}

